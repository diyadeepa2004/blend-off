# Get these from https://developer.spotify.com/dashboard after creating an app.
# No redirect URI needed for this app - we only use Client Credentials flow
# (app-only, no user login), since Blend links are already public playlists.
SPOTIPY_CLIENT_ID=your_client_id_here
SPOTIPY_CLIENT_SECRET=your_client_secret_here

# Pick ONE provider for the awards-show narration (added in Day 2)
OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
